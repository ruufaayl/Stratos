{
  "name": "stratos",
  "version": "0.0.0",
  "private": true,
  "description": "Stratos — the intelligent layer above your cloud. AI-native cloud cost intelligence.",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/sync-env.mjs && pnpm --filter web dev",
    "build": "node scripts/sync-env.mjs && pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm --filter web typecheck",
    "engine:dev": "node scripts/run-engine.mjs",
    "engine:test": "node scripts/run-engine-test.mjs",
    "engine:install": "node scripts/install-engine.mjs",
    "db:generate": "pnpm --filter web db:generate",
    "db:push": "pnpm --filter web db:push",
    "db:studio": "pnpm --filter web db:studio"
  }
}
