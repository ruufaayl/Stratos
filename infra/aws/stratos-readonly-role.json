{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Stratos read-only cross-account IAM role. This stack creates a role that Stratos assumes to analyse your cloud spend. It has NO write permissions — it can only describe and read metrics.",
  "Parameters": {
    "ExternalId": {
      "Type": "String",
      "Description": "Unique external ID generated by Stratos for your account (prevents confused-deputy attacks). Paste the value shown in the Stratos onboarding wizard.",
      "MinLength": "8",
      "MaxLength": "64"
    },
    "StratosPrincipal": {
      "Type": "String",
      "Description": "The Stratos IAM principal ARN that will assume this role.",
      "Default": "arn:aws:iam::000000000000:root"
    },
    "RoleName": {
      "Type": "String",
      "Default": "StratosReadOnly",
      "Description": "Name for the IAM role. Change only if you have naming constraints."
    }
  },
  "Resources": {
    "StratosReadOnlyRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": { "Ref": "RoleName" },
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": { "Ref": "StratosPrincipal" }
              },
              "Action": "sts:AssumeRole",
              "Condition": {
                "StringEquals": {
                  "sts:ExternalId": { "Ref": "ExternalId" }
                }
              }
            }
          ]
        },
        "Description": "Stratos read-only analysis role. No write permissions.",
        "Policies": [
          {
            "PolicyName": "StratosReadOnlyPolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "EC2ReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "ec2:DescribeInstances",
                    "ec2:DescribeInstanceTypes",
                    "ec2:DescribeVolumes",
                    "ec2:DescribeSnapshots",
                    "ec2:DescribeReservedInstances",
                    "ec2:DescribeSavingsPlans",
                    "ec2:DescribeRegions",
                    "ec2:DescribeAvailabilityZones"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "CloudWatchReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "cloudwatch:GetMetricStatistics",
                    "cloudwatch:GetMetricData",
                    "cloudwatch:ListMetrics",
                    "cloudwatch:DescribeAlarms"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "CostExplorerReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "ce:GetCostAndUsage",
                    "ce:GetCostForecast",
                    "ce:GetReservationCoverage",
                    "ce:GetSavingsPlansCoverage",
                    "ce:GetRightsizingRecommendation"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "RDSReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "rds:DescribeDBInstances",
                    "rds:DescribeDBClusters",
                    "rds:ListTagsForResource"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "S3ReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "s3:ListAllMyBuckets",
                    "s3:GetBucketLocation",
                    "s3:GetBucketTagging"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "STSCallerIdentity",
                  "Effect": "Allow",
                  "Action": "sts:GetCallerIdentity",
                  "Resource": "*"
                }
              ]
            }
          }
        ],
        "Tags": [
          {
            "Key": "ManagedBy",
            "Value": "Stratos"
          },
          {
            "Key": "Purpose",
            "Value": "read-only-cost-analysis"
          }
        ]
      }
    }
  },
  "Outputs": {
    "RoleArn": {
      "Description": "Paste this ARN into the Stratos onboarding wizard.",
      "Value": { "Fn::GetAtt": ["StratosReadOnlyRole", "Arn"] }
    },
    "RoleName": {
      "Description": "The IAM role name.",
      "Value": { "Ref": "StratosReadOnlyRole" }
    }
  }
}
