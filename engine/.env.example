# Stratos engine environment (copy to engine/.env, never commit secrets)

# Identifies which env we're in ("dev" | "staging" | "prod")
STRATOS_ENV=dev

# Shared secret with the Next.js side (matches ENGINE_API_KEY there)
ENGINE_API_KEY=dev-only-change-me

# OPTIONAL: when the engine itself needs to call external APIs
# AWS_REGION=us-east-1
