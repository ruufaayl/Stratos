# =============================================================================
# Stratos — Environment Variables Reference
# =============================================================================
# Copy to .env.local for local development. NEVER commit .env.local to git.

# --- App URL (used in emails, OG images, billing portal return URLs) ---
NEXT_PUBLIC_APP_URL=https://stratos.ai

# --- Clerk (Authentication) ---
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/post-auth
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/post-auth
# Clerk webhook signing secret (from Clerk dashboard → Webhooks)
CLERK_WEBHOOK_SECRET=whsec_...

# --- Database (Neon PostgreSQL) ---
# Get from: https://console.neon.tech → Project → Connection Details
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host/dbname?sslmode=require

# --- Stripe (Billing) ---
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Get Price ID from: Stripe → Products → Pro Plan → Price ID
STRIPE_PRO_PRICE_ID=price_...

# --- Resend (Email) ---
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...

# --- PostHog (Analytics) ---
# Get from: https://us.posthog.com → Project → Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Cron Security ---
# Random secret string — set same value in Vercel env + this file
# Used to authenticate Vercel Cron calls to /api/digest
CRON_SECRET=your-random-secret-here

# --- Engine (Stratos Python Engine) ---
# Local dev: http://localhost:8000
# Production: your Modal.com deployment URL
STRATOS_ENGINE_URL=http://localhost:8000
ENGINE_API_KEY=dev-only-change-me

# --- Anthropic (Claude AI) ---
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Redis (Upstash) ---
# Get from: https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- AWS Integration (for real customer accounts) ---
# IAM principal ARN that customer cross-account roles must trust
STRATOS_AWS_PRINCIPAL=arn:aws:iam::123456789012:root
# 32+ char high-entropy secret — derives per-org AWS external-ids
STRATOS_EXTERNAL_ID_SECRET=change-me-to-a-long-random-string

# --- Sentry (Error Monitoring) — Optional ---
# Get from: https://sentry.io → Project → Settings → SDK Setup
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org
SENTRY_PROJECT=stratos-web
