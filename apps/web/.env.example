# =============================================================================
# STRATOS — environment variables example
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# ---- Database (Neon serverless Postgres) -----------------------------------
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host/db?sslmode=require"

# ---- Clerk (auth) ----------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ---- Engine (FastAPI service) ----------------------------------------------
ENGINE_URL="http://localhost:8000"
ENGINE_API_KEY="dev-only-change-me"

# ---- Anthropic Claude (reasoning layer) ------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."

# ---- Redis (Upstash) -------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Resend (transactional email) ------------------------------------------
RESEND_API_KEY=""

# ---- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""

# ---- App config ------------------------------------------------------------
# Public URL where the app is hosted (used for emails, redirects, etc.)
NEXT_PUBLIC_APP_URL=""
# Random secret protecting the /api/digest/cron endpoint from public hits
CRON_SECRET=""
# AWS IAM principal ARN that customer cross-account roles must trust
STRATOS_AWS_PRINCIPAL=""

# 32+ char high-entropy secret — derives per-org AWS external-ids
STRATOS_EXTERNAL_ID_SECRET=change-me-to-a-long-random-string

# ---- PostHog (product analytics) -------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ---- Observability (optional) ----------------------------------------------
SENTRY_DSN=""
